# Nix build outputs
result
result-*

# macOS noise
.DS_Store

# direnv
.direnv/

# Claude Code local overrides
.claude/settings.local.json

# Claude Code skills: only repository-workflow skills are tracked
# (allowlist below); personal skills live in user scope (~/.claude/skills),
# and skill-manager artifacts (vendored copies, lockfile) stay out.
.claude/skills/*
!.claude/skills/adr-new
!.claude/skills/migration-check
.agents/
skills-lock.json

# Secret guards (ADR 0009): these must never be committed
*.pem
*.key
id_rsa*
id_ed25519*
*.token
.env
.env.*
!.env.example
